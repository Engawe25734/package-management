<!DOCTYPE html>
<html>
<head>
<!--
Name:Elvis ngawe
Date: May 27, 2026
Purpose: This program calculates a user's target heart rate range.
-->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Target Heart Rate Calculator</title>

    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <div class="wrapper">

        <h1>Elvis ngawe, Target Heart Rate</h1>

        <div class="input-section">

            <label for="age">Your Age</label>

            <input type="number" id="age">

            <button onclick="calculateTHR()">
                Calculate Target Heart Rate
            </button>

        </div>

        <p id="result">
            Target Heart Rate:
        </p>

    </div>

    <script>

        function calculateTHR() {

            // Get user's age
            let age = document.getElementById("age").value;

            // Validate age
            if (age < 0 || age > 125 || age === "") {

                alert("Please enter a valid age between 0 and 125.");

                return;
            }

            // Maximum heart rate
            let maxHR = 220 - age;

            // Minimum target heart rate
            let minTHR = Math.floor(maxHR * 0.5);

            // Maximum target heart rate
            let maxTHR = Math.floor(maxHR * 0.85);

            // Display result
            document.getElementById("result").innerHTML =
                "Target Heart Rate: " +
                minTHR +
                " to " +
                maxTHR +
                " Beats Per Minute";
        }

    </script>

</body>
</html>
