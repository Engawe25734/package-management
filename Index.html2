<!DOCTYPE html>
<html lang="en">
<head>
    <!--
        Name: Elvis ngawe
        Date: 2026-06-10
        Purpose: Contact page with modal popup, tooltip, and persistent dark mode using localStorage.
    -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Form with Storage Features</title>

    <style>
        /* =========================
           BASIC PAGE STYLING
        ========================= */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            transition: background 0.3s, color 0.3s;
            background: #f4f4f4;
            color: #111;
        }

        header {
            background: #333;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .container {
            padding: 20px;
        }

        /* =========================
           DARK MODE
        ========================= */
        body.dark-mode {
            background: #121212;
            color: #f4f4f4;
        }

        body.dark-mode header {
            background: #000;
        }

        /* =========================
           MODAL STYLING
        ========================= */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: white;
            padding: 20px;
            border-radius: 8px;
            width: 300px;
            text-align: center;
        }

        body.dark-mode .modal-content {
            background: #222;
            color: white;
        }

        .close-btn {
            margin-top: 10px;
            padding: 8px 15px;
            cursor: pointer;
        }

        /* =========================
           TOOLTIP STYLING
        ========================= */
        .tooltip {
            position: relative;
            display: inline-block;
        }

        .tooltip .tooltip-text {
            visibility: hidden;
            width: 180px;
            background-color: black;
            color: #fff;
            text-align: center;
            padding: 5px;
            border-radius: 6px;

            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -90px;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .tooltip:hover .tooltip-text {
            visibility: visible;
            opacity: 1;
        }

        /* =========================
           FORM STYLING
        ========================= */
        form {
            max-width: 400px;
            margin: auto;
        }

        input, textarea {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
        }

        button {
            margin-top: 10px;
            padding: 10px;
            cursor: pointer;
        }

        .toggle {
            margin: 10px 0;
        }
    </style>
</head>

<body>

<!-- =========================
     WELCOME MODAL
========================= -->
<div class="modal" id="welcomeModal">
    <div class="modal-content">
        <h2>Welcome</h2>
        <p>This page is a work in progress.</p>
        <button class="close-btn" onclick="closeModal()">Close</button>
    </div>
</div>

<header>
    <h1>Contact Form</h1>
</header>

<div class="container">

    <!-- DARK MODE TOGGLE -->
    <div class="toggle">
        <label>
            <input type="checkbox" id="darkToggle" onchange="toggleDarkMode()">
            Enable Dark Mode
        </label>
    </div>

    <!-- CONTACT FORM -->
    <form>
        <input type="text" placeholder="Your Name" required>
        <input type="email" placeholder="Your Email" required>
        <textarea placeholder="Your Message" rows="5" required></textarea>

        <!-- TOOLTIP ON SUBMIT -->
        <div class="tooltip">
            <button type="submit">Submit</button>
            <span class="tooltip-text">Click to send your message!</span>
        </div>
    </form>

</div>

<script>
    // =========================
    // MODAL FUNCTIONALITY
    // =========================

    const modal = document.getElementById("welcomeModal");

    // Show modal on page load
    window.onload = function () {
        modal.style.display = "flex";

        // Load dark mode preference from localStorage
        if (localStorage.getItem("darkMode") === "enabled") {
            document.body.classList.add("dark-mode");
            document.getElementById("darkToggle").checked = true;
        }
    };

    // Close modal
    function closeModal() {
        modal.style.display = "none";
    }

    // =========================
    // DARK MODE TOGGLE
    // =========================

    function toggleDarkMode() {
        const toggle = document.getElementById("darkToggle");

        if (toggle.checked) {
            document.body.classList.add("dark-mode");
            localStorage.setItem("darkMode", "enabled");
        } else {
            document.body.classList.remove("dark-mode");
            localStorage.setItem("darkMode", "disabled");
        }
    }
</script>

</body>
</html>
