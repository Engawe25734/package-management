body {
    background-color: white;
    font-family: "Times New Roman", serif;
    margin: 0;
    padding: 0;
}

.wrapper {
    width: 80%;
    margin: 80px auto;
}

h1 {
    font-size: 55px;
    font-weight: bold;
    margin-bottom: 60px;
}

.input-section {
    display: flex;
    align-items: center;
    gap: 10px;
}

label {
    font-size: 28px;
}

input {
    width: 350px;
    height: 35px;
    font-size: 24px;
    padding-left: 10px;
}

button {
    height: 42px;
    font-size: 18px;
    cursor: pointer;
}

#result {
    margin-top: 90px;
    font-size: 32px;
}
